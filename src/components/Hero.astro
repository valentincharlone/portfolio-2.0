---
const socialLinks = [
  {
    name: "GitHub",
    href: "https://github.com/valentincharlone",
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/valentincharlone",
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
];
---

<section
  id="about"
  class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden"
>
  <!-- Background glow effect -->
  <div class="absolute inset-0 overflow-hidden">
    <div
      class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl animate-gradient"
    >
    </div>
    <div
      class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl animate-gradient"
      style="animation-delay: 4s;"
    >
    </div>
  </div>

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <div class="opacity-0 animate-fade-in-up">
      <p class="text-accent font-mono text-sm mb-4">Hello, I'm</p>
    </div>

    <h1
      class="text-5xl md:text-7xl font-bold text-text-primary mb-6 opacity-0 animate-fade-in-up animation-delay-100"
    >
      Valentin Charlone
    </h1>

    <h2
      class="text-2xl md:text-3xl font-semibold text-text-secondary mb-6 opacity-0 animate-fade-in-up animation-delay-200"
    >
      Frontend Engineer
    </h2>

    <p
      class="text-lg text-text-muted max-w-2xl mx-auto mb-10 leading-relaxed opacity-0 animate-fade-in-up animation-delay-300"
    >
      Specialized in React, Next.js, TypeScript, and modern UI systems.
      Experienced in building complex dashboards, scalable component
      architectures, and high-performance web applications with a strong focus
      on product quality and user experience.
    </p>

    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12 opacity-0 animate-fade-in-up animation-delay-400"
    >
      <a
        href="#projects"
        class="inline-flex items-center px-6 py-3 text-sm font-medium text-background bg-text-primary rounded-lg hover:bg-text-primary/90 transition-all duration-200 hover:shadow-lg hover:shadow-white/10"
      >
        View Projects
        <svg
          class="ml-2 w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center px-6 py-3 text-sm font-medium text-text-primary border border-border rounded-lg hover:bg-surface hover:border-text-muted transition-all duration-200"
      >
        Contact Me
        <svg
          class="ml-2 w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
    </div>

    <div
      class="flex items-center justify-center gap-6 opacity-0 animate-fade-in-up animation-delay-400"
    >
      {
        socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 text-text-muted hover:text-accent transition-colors duration-200"
            aria-label={social.name}
          >
            <Fragment set:html={social.icon} />
          </a>
        ))
      }
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-fade-in-up animation-delay-400"
  >
    <div
      class="w-6 h-10 rounded-full border-2 border-border flex items-start justify-center p-1"
    >
      <div class="w-1.5 h-3 bg-text-muted rounded-full animate-bounce"></div>
    </div>
  </div>
</section>
