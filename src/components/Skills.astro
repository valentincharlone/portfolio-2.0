---

<section id="skills" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-accent font-mono text-sm mb-4">What I work with</p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">Tech Stack</h2>
      <p class="text-text-muted max-w-2xl mx-auto">
        The technologies and tools I use to bring ideas to life
      </p>
    </div>
    
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 md:gap-6">
      {skills.map(skill => (
        <div class="group relative p-6 bg-surface border border-border rounded-xl hover:border-accent/50 hover:bg-surface-hover transition-all duration-300">
          <div class="absolute inset-0 bg-gradient-to-br from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-xl"></div>
          <div class="relative flex flex-col items-center text-center">
            <div class="text-text-muted group-hover:text-accent transition-colors duration-300 mb-3">
              <Fragment set:html={skill.icon} />
            </div>
            <span class="text-sm font-medium text-text-secondary group-hover:text-text-primary transition-colors duration-300">
              {skill.name}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
